#!/usr/bin/env sh

theme=$1
if [[ $theme == "" ]]; then
	theme=$(ls $XDG_CONFIG_HOME/alacritty/mythemes | rofi -dmenu -p "select alacritty theme")
fi

if [[ ! $theme == "" ]]; then
	ln -sf $XDG_CONFIG_HOME/alacritty/mythemes/$theme $XDG_CONFIG_HOME/alacritty/theme.yml
	touch $XDG_CONFIG_HOME/alacritty/alacritty.yml
fi
